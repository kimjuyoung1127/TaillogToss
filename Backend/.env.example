# TaillogToss Backend — 환경 변수 템플릿
# 실제 값은 .env 파일에 작성 (git에 커밋하지 않음)

# Runtime
ENVIRONMENT=development

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres.xxx:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# Supabase Auth (Remote Verification)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# OpenAI (AI Coaching)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# AI Cost Control
AI_DAILY_BUDGET_USD=5.0
AI_MONTHLY_BUDGET_USD=30.0
AI_USER_DAILY_LIMIT=6
AI_USER_BURST_LIMIT=2
AI_USER_BURST_WINDOW_MIN=10
AI_LLM_TIMEOUT_SEC=8
AI_MAX_RETRIES=1
