{
  "permissions": {
    "allow": [
      "WebFetch(domain:www.gpters.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(npx --version)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx create-granite-app@latest --help)",
      "Bash(git status -u)",
      "Bash(git status -u --short)",
      "Read(/tmp/**)"
    ],
    "additionalDirectories": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-typecheck.sh"
          }
        ]
      }
    ]
  }
}
