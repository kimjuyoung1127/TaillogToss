node_modules/
.yarn/cache/
.pnp.*

# 빌드 산출물
dist/
build/
.next/
.expo/
.swc/
*.ait

# Python 가상환경
Backend/.venv/
Backend/venv/
**/__pycache__/
**/*.py[cod]
**/*.egg-info/

# OS / IDE
.DS_Store
.idea/
.vscode/

