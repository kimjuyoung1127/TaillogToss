{
  "name": "taillog-toss",
  "version": "0.1.0",
  "private": true,
  "description": "TaillogToss — 반려견 행동 교정 SaaS (Toss 미니앱)",
  "scripts": {
    "dev": "set -a && source .env 2>/dev/null; set +a; granite dev",
    "build": "ait build",
    "test": "npm run test:app && npm run test:edge",
    "test:app": "jest --config jest.config.js --testPathIgnorePatterns=/supabase/functions/ --passWithNoTests",
    "test:edge": "jest --config jest.edge.config.js --runInBand --testPathPattern=supabase/functions --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@apps-in-toss/framework": "^2.4.1",
    "@granite-js/native": "1.0.4",
    "@granite-js/react-native": "1.0.4",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "@toss/tds-react-native": "2.0.2",
    "brick-module": "0.5.0",
    "react": "19.2.3",
    "react-native": "0.84.0"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/runtime": "7.28.4",
    "@eslint/js": "^9.17.0",
    "@granite-js/plugin-hermes": "1.0.4",
    "@granite-js/plugin-router": "1.0.4",
    "@testing-library/react-native": "^12.9.0",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "19.2.3",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "babel-preset-granite": "1.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "jest": "^29.7.0",
    "prettier": "3.4.2",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
}
